{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentgate.dev/schemas/redteam-corpus-v1.schema.json",
  "title": "AgentGate Red-Team Corpus v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "cases"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/case" }
    }
  },
  "$defs": {
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "scenario", "severity", "requirements", "threats", "expected"],
      "properties": {
        "id": { "type": "string", "pattern": "^AG-RT-[0-9]{3}$" },
        "title": { "type": "string", "minLength": 1 },
        "scenario": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "severity": { "enum": ["critical", "high", "medium", "low"] },
        "requirements": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "threats": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^TM-[0-9]{2}$" } },
        "expected": {
          "type": "object",
          "additionalProperties": false,
          "required": ["outcome", "code"],
          "properties": {
            "outcome": { "enum": ["prevented", "confirmed", "detected", "not_detected", "not_applicable", "expected_limitation"] },
            "code": { "type": "string", "pattern": "^AG-[A-Z0-9-]+$" }
          }
        }
      }
    }
  }
}
