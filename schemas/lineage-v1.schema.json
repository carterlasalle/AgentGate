{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentgate.dev/schemas/lineage-v1.schema.json",
  "title": "AgentGate Authenticated Lineage v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["claim", "mac"],
  "properties": {
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "sessionId", "serverId", "tool", "label", "argumentsDigest", "issuedAt", "expiresAt", "nonce"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "sessionId": { "type": "string", "minLength": 1, "maxLength": 128 },
        "serverId": { "type": "string", "minLength": 1, "maxLength": 128 },
        "tool": { "type": "string", "minLength": 1, "maxLength": 256 },
        "label": { "type": "string", "minLength": 1, "maxLength": 256, "pattern": "^[A-Za-z0-9._-]+$" },
        "argumentsDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "issuedAt": { "type": "integer", "minimum": 0 },
        "expiresAt": { "type": "integer", "minimum": 0 },
        "nonce": { "type": "string", "minLength": 16, "maxLength": 128 }
      }
    },
    "mac": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
